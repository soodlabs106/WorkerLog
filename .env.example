# Copy this file to .env and fill in your own values.
# Get these from your Supabase project: Settings > API

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: a shared PIN staff must enter to mark a ticket resolved.
# This is a soft deterrent for a no-login community tool, not real security.
# Leave blank to disable the PIN check entirely.
VITE_STAFF_PIN=1234
